{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "typewriter-chat-website",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-27",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "vars": {
    "VLLM_URL": "http://localhost:8003",
    "VLLM_MODEL": "typewriter-mega"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
