{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "typewriter-chat-website",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-27",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "vars": {
    "VLLM_URL": "https://angeles-nevada-surprising-shed.trycloudflare.com",
    "VLLM_MODEL": "typewriter-1938-sft-v1"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
